{
  "name": "walls-monorepo",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "turbo dev",
    "dev:public": "turbo dev --filter=public-site",
    "dev:adpilot": "turbo dev --filter=adpilot",
    "dev:portal": "turbo dev --filter=portal",
    "dev:wallie": "turbo dev --filter=wallie",
    "dev:wallie-mobile": "turbo dev --filter=wallie-mobile",
    "ios:wallie-mobile": "pnpm --filter wallie-mobile ios:device",
    "android:wallie-mobile": "pnpm --filter wallie-mobile android:device",
    "build": "turbo build",
    "lint": "turbo lint",
    "start": "turbo start",
    "db:schema": "pnpm --filter @walls/supabase db:schema",
    "sync:icons": "pnpm --filter @walls/config sync:icons"
  },
  "devDependencies": {
    "turbo": "^2.5.4"
  },
  "pnpm": {
    "overrides": {
      "wallie-mobile>@types/react": "~18.3.12",
      "wallie-mobile>@types/react-dom": "~18.3.1"
    }
  }
}
