# Copy to .env at the monorepo root and fill in your Supabase project values.
# All apps in this repo read from the root .env file.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Marketing site portal link (auth lives on walls.agency, not wallsentertainment.com)
NEXT_PUBLIC_WALLS_AGENCY_URL=https://walls.agency

# Server-only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct Postgres connection (Settings → Database → Connection string → URI)
# Used by `pnpm db:schema` to generate packages/supabase/generated.json
SUPABASE_DB_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres
