# Environment files (monorepo root)
#
# Local development:
#   cp .env.example .env.local
#   Fill in values and run `pnpm dev` — only `.env.local` is loaded in development.
#
# Production (Vercel / `next build`):
#   Use root `.env` on the build machine OR set the same keys in the Vercel project dashboard.
#   Do not commit secrets; `.env` remains gitignored.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Marketing site portal link (auth lives on portal.walls.agency)
NEXT_PUBLIC_WALLS_AGENCY_URL=https://portal.walls.agency
# Optional alias — same value as above if you prefer an explicit name
# NEXT_PUBLIC_PORTAL_URL=https://portal.walls.agency

# Internal app URLs (used for post-login redirects and auth middleware)
# Production AdPilot: https://adpilot.walls.agency
# Local dev: http://localhost:3001
NEXT_PUBLIC_ADPILOT_URL=http://localhost:3001
NEXT_PUBLIC_ADPILOT_APP_SLUG=adpilot

# Meta Marketing API OAuth (AdPilot settings → Connect Meta)
# Login URI:  {NEXT_PUBLIC_ADPILOT_URL}/api/oauth/meta/login
# Callback URI: {NEXT_PUBLIC_ADPILOT_URL}/api/oauth/meta/callback
NEXT_PUBLIC_META_ANALYTICS_APP_ID=your-meta-app-id
META_ANALYTICS_APP_ID=your-meta-app-id
META_ANALYTICS_APP_SECRET=your-meta-app-secret

# Public marketing site URL (used by portal "Back home" and legal links)
NEXT_PUBLIC_WALLS_PUBLIC_SITE_URL=https://wallsentertainment.com

# Server-only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct Postgres connection (Settings → Database → Connection string → URI)
# Used by `pnpm db:schema` to generate packages/supabase/generated.json
SUPABASE_DB_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres
