# Environment files (monorepo root)
#
# Local development:
#   cp .env.example .env.local
#   Fill in values and run `pnpm dev` — only `.env.local` is loaded in development.
#
# Production (Vercel / `next build`):
#   Use root `.env` on the build machine OR set the same keys in the Vercel project dashboard.
#   Do not commit secrets; `.env` remains gitignored.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Portal (auth launcher). Must NOT share a port with any app below.
# Production: https://portal.kenoo.io
# Local dev: http://localhost:3002
NEXT_PUBLIC_WALLS_AGENCY_URL=http://localhost:3002
# Optional alias — same value as above if you prefer an explicit name
# NEXT_PUBLIC_PORTAL_URL=http://localhost:3002

# Internal app URLs (used for post-login redirects and auth middleware)
# Production AdPilot: https://adpilot.kenoo.io
# Local dev: http://localhost:3001 (AdPilot — not the portal)
NEXT_PUBLIC_ADPILOT_URL=http://localhost:3001
NEXT_PUBLIC_ADPILOT_APP_SLUG=adpilot

# Wallie AI assistant
# Production: https://wallie.kenoo.io
# Local dev: http://localhost:3003
NEXT_PUBLIC_WALLIE_URL=http://localhost:3003
# Optional wallie-mobile voice override (transcribe/TTS). Physical devices auto-use production when URL is localhost.
# NEXT_PUBLIC_WALLIE_MOBILE_WEB_URL=https://wallie.kenoo.io
# Remote wallie-api on Hetzner (datalabs). Web proxies chat here; mobile calls it directly.
NEXT_PUBLIC_WALLIE_API_URL=https://datalabs.wallsentertainment.com

# Settings app
# Production: https://settings.kenoo.io
# Local dev: http://localhost:3004
NEXT_PUBLIC_SETTINGS_URL=http://localhost:3004
NEXT_PUBLIC_SETTINGS_APP_SLUG=settings

# Health app
# Production: https://health.kenoo.io
# Local dev: http://localhost:3005
NEXT_PUBLIC_HEALTH_URL=http://localhost:3005
NEXT_PUBLIC_HEALTH_APP_SLUG=health

# Calendar app
# Production: https://calendar.kenoo.io
# Local dev: http://localhost:3006
NEXT_PUBLIC_CALENDAR_URL=http://localhost:3006
NEXT_PUBLIC_CALENDAR_APP_SLUG=calendar

# Projects app
# Production: https://projects.kenoo.io
# Local dev: http://localhost:3007
NEXT_PUBLIC_PROJECTS_URL=http://localhost:3007
NEXT_PUBLIC_PROJECTS_APP_SLUG=projects

# Admin app (organization admin — SaaS)
# Production: https://admin.kenoo.io
# Local dev: http://localhost:3008
NEXT_PUBLIC_ADMIN_URL=http://localhost:3008
NEXT_PUBLIC_ADMIN_APP_SLUG=admin

# Console app (internal Kenoo staff — system-wide)
# Production: https://console.kenoo.io
# Local dev: http://localhost:3011
NEXT_PUBLIC_CONSOLE_URL=http://localhost:3011
NEXT_PUBLIC_CONSOLE_APP_SLUG=console

# CRM app
# Production: https://crm.kenoo.io
# Local dev: http://localhost:3009
NEXT_PUBLIC_CRM_URL=http://localhost:3009
NEXT_PUBLIC_CRM_APP_SLUG=crm

# Ledger app
# Production: https://ledger.kenoo.io
# Local dev: http://localhost:3010
NEXT_PUBLIC_LEDGER_URL=http://localhost:3010
NEXT_PUBLIC_LEDGER_APP_SLUG=ledger

# Strava OAuth (Health → Connect Strava)
# Register the Authorization Callback Domain in the Strava app settings.
# STRAVA_REDIRECT_URI must be {NEXT_PUBLIC_HEALTH_URL}/api/strava/callback
# Local dev: http://localhost:3005/api/strava/callback
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=

# Google OAuth (Settings → Connect Gmail / Calendar)
# Redirect URIs (register in Google Cloud Console):
#   {NEXT_PUBLIC_SETTINGS_URL}/api/google/gmail/callback
#   {NEXT_PUBLIC_SETTINGS_URL}/api/google/calendar/callback
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Optional — Gmail push notifications (Pub/Sub topic for inbox watch)
# GMAIL_PUBSUB_TOPIC=projects/your-project/topics/gmail-push

# Meta Marketing API OAuth (AdPilot settings → Connect Meta)
# Login URI:  {NEXT_PUBLIC_ADPILOT_URL}/api/oauth/meta/login
# Callback URI: {NEXT_PUBLIC_ADPILOT_URL}/api/oauth/meta/callback
NEXT_PUBLIC_META_ANALYTICS_APP_ID=your-meta-app-id
META_ANALYTICS_APP_ID=your-meta-app-id
META_ANALYTICS_APP_SECRET=your-meta-app-secret

# Google Ads API (AdPilot — connect external advertiser accounts)
# Developer token: Google Ads manager account → API Center
# OAuth: same GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET (or Ads-specific client)
# Login URI:  {NEXT_PUBLIC_ADPILOT_URL}/api/oauth/google/login
# Callback URI: {NEXT_PUBLIC_ADPILOT_URL}/api/oauth/google/callback
GOOGLE_ADS_DEVELOPER_TOKEN=your-google-ads-developer-token
# Optional — Kenoo MCC id (digits only, no dashes) for login-customer-id header
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=8896508658

# Shared auth cookie domain for portal + app SSO (production)
SUPABASE_AUTH_COOKIE_DOMAIN=.kenoo.io

# Public marketing site URL (used by portal "Back home" and legal links)
NEXT_PUBLIC_BASE_URL=https://kenoo.io
# Deprecated alias — prefer NEXT_PUBLIC_BASE_URL
# NEXT_PUBLIC_WALLS_PUBLIC_SITE_URL=https://wallsentertainment.com

# Server-only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Amazon SES (admin → organization member invite emails for existing users)
# New users still receive the Supabase Auth invite template; existing users get SES.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-2
SES_FROM_EMAIL=noreply@mail.kenoo.io

# AI scope generation (Projects app — optional)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# PERPLEXITY_API_KEY=

# Cloudflare R2 (all image uploads — avatars, org icons, etc.)
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=your-r2-bucket-name
R2_PUBLIC_BASE=https://assets.wallsentertainment.com

# AdPilot ↔ automation backend (server-only — never expose to the browser)
# Base URL of the dry-run (test-response) service. No trailing slash.
# Local: http://<your-server>:8787 — Production: https://adpilot.yourdomain.com
ADPILOT_API_URL=http://localhost:8787
# This value must match TEST_RESPONSE_API_KEY on the backend algorithm service.
# Sent in the x-api-key header when AdPilot requests a dry-run from the algorithm.
ADPILOT_API_KEY=your-adpilot-api-key

# Direct Postgres connection (Settings → Database → Connection string → URI)
# Used by `pnpm db:schema` to generate packages/supabase/generated.json
SUPABASE_DB_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# Stripe (Kenoo SaaS billing — @walls/billing)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Prefer STRIPE_WEBHOOK_SECRET; snapshot/thin kept for legacy endpoints
STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_WEBHOOK_SECRET_SNAPSHOT=
# STRIPE_WEBHOOK_SECRET_THIN=
# Price IDs from Stripe Dashboard → Products (at least one required for checkout)
STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_ENTERPRISE=price_...
# Or a single default price:
# STRIPE_PRICE_ID=price_...
