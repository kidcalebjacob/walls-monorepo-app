{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "concurrency": "22",
  "globalDependencies": [".env", ".env.local"],
  "globalEnv": [
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY",
    "NEXT_PUBLIC_WALLS_AGENCY_URL",
    "NEXT_PUBLIC_PORTAL_URL",
    "NEXT_PUBLIC_WALLS_PUBLIC_SITE_URL",
    "NEXT_PUBLIC_BASE_URL",
    "NEXT_PUBLIC_ADPILOT_URL",
    "NEXT_PUBLIC_ADPILOT_APP_SLUG",
    "NEXT_PUBLIC_SETTINGS_URL",
    "NEXT_PUBLIC_SETTINGS_APP_SLUG",
    "NEXT_PUBLIC_HEALTH_URL",
    "NEXT_PUBLIC_HEALTH_APP_SLUG",
    "NEXT_PUBLIC_CALENDAR_URL",
    "NEXT_PUBLIC_CALENDAR_APP_SLUG",
    "NEXT_PUBLIC_PROJECTS_URL",
    "NEXT_PUBLIC_PROJECTS_APP_SLUG",
    "NEXT_PUBLIC_ADMIN_URL",
    "NEXT_PUBLIC_ADMIN_APP_SLUG",
    "NEXT_PUBLIC_CONSOLE_URL",
    "NEXT_PUBLIC_CONSOLE_APP_SLUG",
    "NEXT_PUBLIC_CRM_URL",
    "NEXT_PUBLIC_CRM_APP_SLUG",
    "NEXT_PUBLIC_LEDGER_URL",
    "NEXT_PUBLIC_LEDGER_APP_SLUG",
    "NEXT_PUBLIC_WALLIE_URL",
    "NEXT_PUBLIC_META_ANALYTICS_APP_ID",
    "META_ANALYTICS_APP_ID",
    "META_ANALYTICS_APP_SECRET",
    "NEXT_PUBLIC_GOOGLE_CLIENT_ID",
    "APP_BASE_URL",
    "SUPABASE_SERVICE_ROLE_KEY",
    "SUPABASE_AUTH_COOKIE_DOMAIN"
  ],
  "globalPassThroughEnv": [
    "SERPER_API_KEY",
    "STRIPE_SECRET_KEY",
    "STRIPE_WEBHOOK_SECRET",
    "STRIPE_WEBHOOK_SECRET_SNAPSHOT",
    "STRIPE_WEBHOOK_SECRET_THIN",
    "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY",
    "STRIPE_PRICE_ID",
    "STRIPE_PRICE_STARTER",
    "STRIPE_PRICE_PRO",
    "STRIPE_PRICE_ENTERPRISE",
    "STRIPE_PRICE_STARTER_AMOUNT_CENTS",
    "STRIPE_PRICE_PRO_AMOUNT_CENTS",
    "STRIPE_PRICE_ENTERPRISE_AMOUNT_CENTS",
    "WISE_API_TOKEN",
    "WISE_PROFILE_ID",
    "AWS_ACCESS_KEY_ID",
    "AWS_SECRET_ACCESS_KEY",
    "AWS_REGION",
    "MARKETPLACE_USER_JWT_SECRET",
    "TURNSTILE_SECRET_KEY",
    "NEXT_PUBLIC_TURNSTILE_SITE_KEY",
    "RAPID_API_KEY",
    "R2_ACCESS_KEY_ID",
    "R2_SECRET_ACCESS_KEY",
    "R2_ENDPOINT",
    "R2_BUCKET",
    "R2_PUBLIC_BASE",
    "NEXT_PUBLIC_WALLIE_API_URL",
    "OPENAI_API_KEY",
    "ANTHROPIC_API_KEY",
    "PERPLEXITY_API_KEY",
    "YOUTUBE_CLIENT_ID",
    "YOUTUBE_CLIENT_SECRET",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "GOOGLE_ADS_DEVELOPER_TOKEN",
    "GOOGLE_ADS_LOGIN_CUSTOMER_ID",
    "PROXYCURL_API_KEY",
    "APOLLO_API_KEY",
    "SUPABASE_DB_URL",
    "INSTANTLY_API_KEY",
    "INSTANTLY_BASE_URL",
    "TWILIO_ACCOUNT_SID",
    "TWILIO_AUTH_TOKEN"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "start": {
      "cache": false,
      "persistent": true
    }
  }
}
